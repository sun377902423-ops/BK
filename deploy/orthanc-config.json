{
  "DicomAet": "BKSYSPACS",
  "DicomPort": 4242,
  "DicomCheckCalledAet": false,
  "DicomServerEnabled": true,
  "RemoteAccessAllowed": true,
  "AuthenticationEnabled": true,
  "RegisteredUsers": {
    "orthanc": "orthanc"
  },
  "Plugins": [
    "/usr/local/share/orthanc/plugins"
  ],
  "DicomWeb": {
    "Enable": true,
    "EnableWado": true,
    "EnableStow": true,
    "EnableQido": true
  },
  "HttpCompressionEnabled": true,
  "HttpHeaders": {
    "X-Content-Type-Options": "nosniff"
  }
}
