# ============================================================================
# BK-PACS 部署环境变量（测试环境模板）
# ----------------------------------------------------------------------------
# 复制为 .env：cp .env.example .env，然后修改下面所有 CHANGE_ME 值
# .env 已在 .gitignore，请勿提交！
# ============================================================================

# -- 数据库 -------------------------------------------------------------------
POSTGRES_USER=bksys
POSTGRES_PASSWORD=CHANGE_ME_postgres_password_at_least_16_chars
POSTGRES_DB=bksys_med

# -- 后端 ---------------------------------------------------------------------
# JWT_SECRET：必须 >= 32 字符强随机串；轮换时所有用户需要重新登录
# 生成命令：openssl rand -hex 32
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32_to_generate
JWT_EXPIRES_IN=12h

# CORS：用逗号分隔，留空表示允许全部（仅测试环境）
# 例如 https://test.example.com,https://app.example.com
CORS_ORIGINS=

# 上传大小（字节），默认 100MB
UPLOAD_MAX_BYTES=104857600

# -- Orthanc PACS -------------------------------------------------------------
# 与 deploy/orthanc-config.json 中的 RegisteredUsers 必须一致
ORTHANC_USERNAME=orthanc
ORTHANC_PASSWORD=CHANGE_ME_orthanc_password
# Webhook 鉴权令牌（防止外部伪造 Orthanc 回调）
ORTHANC_WEBHOOK_TOKEN=CHANGE_ME_webhook_token_at_least_16_chars
# 对外公布的 DICOM 信息（可选）
SERVER_PUBLIC_IP=
DICOM_PORT=4242
ORTHANC_AET=BKSYSPACS
NETWORK_MODE=STANDARD

# -- LiveKit 视频 -------------------------------------------------------------
# 与 deploy/livekit.yaml 中的 keys 必须一致
LIVEKIT_API_KEY=bksyslivekit
LIVEKIT_API_SECRET=CHANGE_ME_livekit_secret_at_least_32_chars
LIVEKIT_URL=ws://livekit:7880
# LiveKit 公网 IP（用于 STUN/TURN ICE 候选）
LIVEKIT_NODE_IP=

# -- Nginx Orthanc 反代鉴权 ----------------------------------------------------
# base64("ORTHANC_USERNAME:ORTHANC_PASSWORD")，与 ORTHANC_USERNAME/PASSWORD 对应
# 生成命令：echo -n "orthanc:CHANGE_ME_orthanc_password" | base64
ORTHANC_BASIC_AUTH=b3J0aGFuYzpvcnRoYW5j

# -- 部署目标（仅 deploy.sh 使用，不会传给容器） ---------------------------------
DEPLOY_HOST=
DEPLOY_USER=root
DEPLOY_PATH=/root/bksys2
